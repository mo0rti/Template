import {{ package_identifier }}.bootstrap.security.JwtTokenProvider
import {{ package_identifier }}.modules.auth.dto.AuthResponse
{% if "password" in auth_methods %}
import {{ package_identifier }}.modules.auth.dto.LoginRequest
{% endif %}
{% if "google" in auth_methods or "apple" in auth_methods or "facebook" in auth_methods or "microsoft" in auth_methods %}
import {{ package_identifier }}.modules.auth.dto.OAuthCallbackRequest
{% endif %}
import {{ package_identifier }}.modules.auth.dto.RefreshTokenRequest
{% if "password" in auth_methods %}
import {{ package_identifier }}.modules.auth.dto.RegisterRequest
{% endif %}
import {{ package_identifier }}.modules.auth.dto.UserResponse
import {{ package_identifier }}.modules.auth.dto.toResponse
import {{ package_identifier }}.modules.auth.model.AuthProvider
import {{ package_identifier }}.modules.auth.model.User
import {{ package_identifier }}.modules.auth.repository.UserRepository
import {{ package_identifier }}.shared.exception.ConflictException
import {{ package_identifier }}.shared.exception.UnauthorizedException
{% if "password" in auth_methods %}
import org.springframework.security.crypto.password.PasswordEncoder
{% endif %}
import org.springframework.stereotype.Service
import org.springframework.transaction.annotation.Transactional

@Service
class AuthService(
    private val userRepository: UserRepository,
    private val jwtTokenProvider: JwtTokenProvider,
    private val oAuth2UserService: OAuth2UserService,
{% if "password" in auth_methods %}
    private val passwordEncoder: PasswordEncoder
{% endif %}
) {
{% if "password" in auth_methods %}
    private val dummyPasswordHash = passwordEncoder.encode("timing-attack-placeholder")
{% endif %}
{% if "google" in auth_methods or "apple" in auth_methods or "facebook" in auth_methods or "microsoft" in auth_methods %}
    fun oauthCallback(request: OAuthCallbackRequest): AuthResponse {
        val user = oAuth2UserService.processOAuthCallback(request.provider, request.code, request.redirectUri)
        return createAuthResponse(user)
    }
{% endif %}{% if "password" in auth_methods %}

    @Transactional
    fun register(request: RegisterRequest): AuthResponse {
        if (userRepository.existsByEmail(request.email)) {
            throw ConflictException("Email already registered")
        }

        val user = userRepository.save(
            User(
                email = request.email,
                displayName = request.displayName,
                passwordHash = passwordEncoder.encode(request.password),
                authProvider = AuthProvider.LOCAL
            )
        )

        return createAuthResponse(user)
    }

    @Transactional(readOnly = true)
    fun login(request: LoginRequest): AuthResponse {
        val user = userRepository.findByEmail(request.email)
        val passwordHash = user?.passwordHash ?: dummyPasswordHash
        val passwordMatches = passwordEncoder.matches(request.password, passwordHash)
        if (user == null || user.passwordHash == null || !passwordMatches) {
            throw UnauthorizedException("Invalid credentials")
        }

        return createAuthResponse(user)
    }
{% endif %}

    @Transactional(readOnly = true)
    fun refreshToken(request: RefreshTokenRequest): AuthResponse {
        if (!jwtTokenProvider.validateRefreshToken(request.refreshToken)) {
            throw UnauthorizedException("Invalid or expired refresh token")
        }

        val userId = jwtTokenProvider.getUserIdFromToken(request.refreshToken)
        val user = userRepository.findById(userId)
            .orElseThrow { UnauthorizedException("User not found") }

        return createAuthResponse(user)
    }

    @Transactional(readOnly = true)
    fun getCurrentUser(user: User): UserResponse = user.toResponse()

    private fun createAuthResponse(user: User) = AuthResponse(
        accessToken = jwtTokenProvider.generateAccessToken(user),
        refreshToken = jwtTokenProvider.generateRefreshToken(user),
        expiresIn = jwtTokenProvider.getAccessTokenExpiry(),
        user = user.toResponse()
    )
}
